    "from tldraw import MonkeyWidget\n",
    "\n",
    "m = MonkeyWidget(width=900, height=440)\n",
    "\n",
    "def on_position_change(change):\n",
    "    print(f\"🐒 monkey at: ({m.x:.1f}, {m.y:.1f})\")\n",
    "\n",
    "m.observe(on_position_change, names=['x', 'y'])\n",
    "m"
